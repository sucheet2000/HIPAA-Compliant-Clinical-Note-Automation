# HIPAA-Compliant Clinical Note Automation Tool
# Environment Configuration
# Copy this file to .env and fill in real values.
# ⚠️  NEVER commit .env to Git.

# ===== ANTHROPIC API =====
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-api-key-here

# ===== DATABASE - POSTGRESQL (AUDIT LOGS) =====
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://clinicaluser:CHANGE_ME@localhost:5432/clinical_notes_audit

# ===== DATABASE - MONGODB (FHIR DATA) =====
# Format: mongodb://user:password@host:port/database?authSource=admin
MONGODB_URL=mongodb://clinicaluser:CHANGE_ME@localhost:27017/clinical_notes_fhir?authSource=admin

# ===== APPLICATION SETTINGS =====
LOG_DIR=/app/logs
OUTPUT_DIR=/app/output

# ===== CLAUDE MODEL =====
# Optional: Override the default model
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# ===== FLASK WEB SERVER =====
FLASK_ENV=production
# Set to False in production; True only for local dev
FLASK_DEBUG=False
# Bind only to localhost in production; 0.0.0.0 only inside Docker/VMs
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# ===== SECURITY =====
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_SECURE_RANDOM_KEY

# Comma-separated list of origins allowed to call the /api/* endpoints.
# Leave blank to allow same-origin requests only.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# ===== LOGGING =====
LOG_LEVEL=INFO
